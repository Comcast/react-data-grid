{
  "compilerOptions": {
    "composite": true,
    "emitDeclarationOnly": true,
    "erasableSyntaxOnly": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [],
    "moduleDetection": "force",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "./.cache/ts",
    "target": "esnext",
    "verbatimModuleSyntax": true
  }
}
